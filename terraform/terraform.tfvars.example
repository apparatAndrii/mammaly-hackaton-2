# Скопируйте в terraform.tfvars и заполните значения.
# НЕ коммитьте terraform.tfvars — он в .gitignore.

cloudflare_account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

# GitHub-интеграция (нужна для автодеплоя из репозитория)
enable_git_source = true
github_owner      = "YOUR_GITHUB_USERNAME_OR_ORG"
github_repo_name  = "mammaly-hackaton-2"
production_branch = "main"

# Опционально: кастомный домен
# custom_domain   = "app.example.com"
# zone_id         = "YOUR_ZONE_ID"
# dns_record_name = "app"
